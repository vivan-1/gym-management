// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums - SQLite doesn't support native enums, so we use string fields with validation at the application level
// MembershipStatus: active, expiring_soon, expired
// PaymentStatus: paid, pending, overdue
// PaymentMethod: cash, card, online_transfer
// Gender: male, female, other

model Admin {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  failedLoginAttempts Int           @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  notifications      Notification[]
}

model Member {
  id          String       @id @default(uuid())
  memberId    String       @unique
  fullName    String
  email       String       @unique
  phone       String
  dateOfBirth DateTime
  gender      String       // male, female, other
  address     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  payments    Payment[]
}

model Membership {
  id             String    @id @default(uuid())
  memberId       String
  startDate      DateTime
  endDate        DateTime
  durationMonths Int
  status         String    @default("active") // active, expiring_soon, expired
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  member         Member    @relation(fields: [memberId], references: [id])
  payments       Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  membershipId  String
  memberId      String
  amount        Float
  paymentDate   DateTime
  paymentMethod String   // cash, card, online_transfer
  status        String   @default("pending") // paid, pending, overdue
  createdAt     DateTime @default(now())
  membership    Membership @relation(fields: [membershipId], references: [id])
  member        Member     @relation(fields: [memberId], references: [id])
}

model Notification {
  id              String   @id @default(uuid())
  adminId         String
  type            String   // membership_expiring_soon, membership_expired, payment_overdue, payment_received
  title           String
  message         String
  relatedMemberId String?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
  admin           Admin    @relation(fields: [adminId], references: [id])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
